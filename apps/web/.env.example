# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (Phase 0 Week 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud SQL — games corpus (Phase 1 W1)
GAMES_DATABASE_HOST=
GAMES_DATABASE_PORT=5432
GAMES_DATABASE_USER=
GAMES_DATABASE_PASSWORD=
GAMES_DATABASE_NAME=postgres
GAMES_DATABASE_SSLMODE=require

# Sentry (Phase 0 Week 1)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog (Phase 0 Week 1)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Scout evidence-prose LLM (Phase 1 W5)
# Provider selector: 'deepseek' (default) | 'anthropic'
# Set the matching API key below for whichever you select. Leave both unset
# to skip prose generation entirely (match cards fall back to bullet reasons).
SCOUT_PROSE_PROVIDER=deepseek
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# Stripe (Phase 1 + Phase 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Lichess OAuth (Phase 0 Week 4)
LICHESS_OAUTH_CLIENT_ID=
LICHESS_OAUTH_CLIENT_SECRET=
