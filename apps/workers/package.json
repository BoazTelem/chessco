{
  "name": "@chessco/workers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fide:ingest": "tsx src/fide/run.ts",
    "fide:ingest:test": "tsx src/fide/run.ts --max-players 100",
    "icf:ingest": "tsx src/icf/run.ts",
    "icf:ingest:test": "tsx src/icf/run.ts --max-pages 2",
    "lichess:dump": "tsx src/lichess-dumps/run.ts",
    "lichess:dump:dry": "tsx src/lichess-dumps/run.ts --dry-run",
    "chesscom:titled": "tsx src/chesscom-titled/run.ts",
    "chesscom:country": "tsx src/chesscom-country/run.ts",
    "stage2": "tsx src/identification/run.ts",
    "features:run": "tsx src/features/run.ts",
    "features:card": "tsx src/features/cardinality.ts",
    "features:inspect": "tsx src/features/inspect.ts",
    "games-db:migrate": "tsx src/games-db-migrate.ts",
    "games-db:verify": "tsx src/games-db-verify.ts",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(no lint yet)\" && exit 0"
  },
  "dependencies": {
    "@chessco/db": "workspace:*",
    "cheerio": "^1.0.0",
    "chess.js": "^1.4.0",
    "drizzle-orm": "^0.36.4",
