# Root-level env template. Copy individual values into apps/web/.env.local.
# All real secrets are managed in Vercel env (production) and GitHub Secrets (CI).
# See apps/web/.env.example for the web app's specific keys.

# Supabase (Phase 0 Week 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (Phase 1)
ANTHROPIC_API_KEY=

# Stripe (Phase 1 subscriptions, Phase 4 Connect)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Upstash Redis (Phase 3)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Lichess OAuth (Phase 0 Week 4)
LICHESS_OAUTH_CLIENT_ID=
LICHESS_OAUTH_CLIENT_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
