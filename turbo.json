{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env*", "tsconfig.base.json", ".npmrc"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "SUPABASE_SERVICE_ROLE_KEY",
        "DEEPSEEK_API_KEY",
        "GAMES_DATABASE_HOST",
        "GAMES_DATABASE_PORT",
        "GAMES_DATABASE_USER",
        "GAMES_DATABASE_PASSWORD",
        "GAMES_DATABASE_NAME",
        "GAMES_DATABASE_SSLMODE",
        "SUPER_ADMIN_EMAIL",
        "PRACTICE_WS_TICKET_SECRET",
        "PRACTICE_SETTLE_SECRET",
        "PRACTICE_DATABASE_URL"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
